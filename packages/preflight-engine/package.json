{
  "name": "@shiproof/preflight-engine",
  "version": "0.1.0",
  "description": "Pure, deterministic rules engine for the high-frequency mechanical App Store rejection causes (privacy manifest, required-reason APIs, PII usage descriptions, metadata).",
  "license": "MIT",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "files": [
    "dist",
    "!dist/**/__tests__/**",
    "README.md"
  ],
  "scripts": {
    "build": "tsc -b",
    "test": "tsc -b && node --test \"dist/**/*.test.js\""
  },
  "keywords": [
    "app-store",
    "ios",
    "privacy-manifest",
    "app-review",
    "preflight"
  ],
  "sideEffects": false,
  "repository": {
    "type": "git",
    "url": "git+https://github.com/BhaveshThapar/Shiproof.git",
    "directory": "packages/preflight-engine"
  },
  "homepage": "https://github.com/BhaveshThapar/Shiproof/tree/main/packages/preflight-engine#readme",
  "bugs": "https://github.com/BhaveshThapar/Shiproof/issues",
  "publishConfig": {
    "access": "public"
  }
}
