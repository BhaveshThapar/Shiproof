{
  "name": "@aerodeploy/cli",
  "version": "0.1.0",
  "description": "AeroDeploy pre-flight CLI: scan an iOS project for mechanical App Store rejection causes before you submit.",
  "license": "MIT",
  "type": "module",
  "bin": {
    "aerodeploy": "./dist/index.js"
  },
  "files": [
    "dist",
    "!dist/**/__tests__/**",
    "!dist/eval/**",
    "README.md"
  ],
  "scripts": {
    "build": "tsc -b",
    "test": "tsc -b && node --test \"dist/**/*.test.js\""
  },
  "dependencies": {
    "@aerodeploy/preflight-engine": "0.1.0"
  },
  "keywords": [
    "app-store",
    "ios",
    "app-review",
    "preflight",
    "cli",
    "ci"
  ],
  "repository": {
    "type": "git",
    "url": "git+https://github.com/BhaveshThapar/AeroDeploy.git",
    "directory": "packages/cli"
  },
  "homepage": "https://github.com/BhaveshThapar/AeroDeploy/tree/main/packages/cli#readme",
  "bugs": "https://github.com/BhaveshThapar/AeroDeploy/issues",
  "publishConfig": {
    "access": "public"
  }
}
