{
  "name": "aerodeploy-preflight",
  "version": "0.1.0",
  "private": true,
  "description": "AeroDeploy open-source pre-flight: catch the mechanical App Store rejection causes before you submit.",
  "license": "MIT",
  "type": "module",
  "workspaces": [
    "packages/preflight-engine",
    "packages/cli"
  ],
  "scripts": {
    "build": "tsc -b",
    "typecheck": "tsc -b --noEmit false && tsc -b",
    "clean": "tsc -b --clean",
    "test": "npm run build && node --test \"packages/*/dist/**/*.test.js\"",
    "eval": "npm run build && node packages/cli/dist/eval/run.js",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "format": "prettier --write .",
    "format:check": "prettier --check ."
  },
  "devDependencies": {
    "@eslint/js": "^9.39.4",
    "@types/node": "^22.10.0",
    "eslint": "^9.39.4",
    "eslint-config-prettier": "^9.1.2",
    "prettier": "^3.8.4",
    "typescript": "^5.7.2",
    "typescript-eslint": "^8.61.1"
  },
  "engines": {
    "node": ">=20"
  }
}
